# REQUIRED: Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SECURITY: Admin Setup (MUST be false in production)
# Set to true temporarily ONLY to bootstrap the first admin user,
# then set back to false immediately.
ALLOW_ADMIN_SETUP=false
ADMIN_SETUP_SECRET_KEY=change-me-to-a-long-random-secret

# Email Configuration (using EmailJS)
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key
EMAILJS_SERVICE_ID=service_your_service_id
EMAILJS_ORDER_TEMPLATE_ID=template_order_confirmation
EMAILJS_SHIPPED_TEMPLATE_ID=template_order_shipped

# Admin Email for order notifications
ADMIN_EMAIL=admin@example.com